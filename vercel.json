{
  "version": 2,
  "builds": [
    {
      "src": "api/*.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "api/$1"
    },
    {
      "src": "/(.*)",
      "dest": "api/$1"
    }
  ],
  "env": {
    "PYTHONPATH": "."
  },
  "regions": ["blr1"],
  "functions": {
    "api/dtf_pipeline.py": {
      "memory": 1024,
      "timeout": 120
    }
  }
}