# DTF Automation Environment Variables
# Copy this file to .env.local and fill in your values

# ===========================================
# Required: OpenAI Content Safety
# ===========================================
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# ===========================================
# Required: AWS S3 Configuration
# ===========================================
# Get from AWS IAM → Users → Your User → Security Credentials
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
AWS_REGION=ap-south-1  # Mumbai region for India

# S3 bucket name (create this in AWS S3 console)
S3_BUCKET_NAME=mynarrative-dtf

# ===========================================
# Required: Shopify Webhook Security
# ===========================================
# Get from: Settings → Notifications → Webhooks → Your webhook → API secret
SHOPIFY_WEBHOOK_SECRET=your-webhook-secret-here

# Optional: For accessing Shopify Admin API (for discount codes)
SHOPIFY_API_KEY=your-shopify-api-key
SHOPIFY_API_SECRET=your-shopify-api-secret
SHOPIFY_STORE_URL=your-store.myshopify.com

# ===========================================
# Optional: API Security
# ===========================================
# Generate a random string for API key authentication
DTF_API_KEY=your-random-api-key-here

# ===========================================
# Optional: Notifications
# ===========================================
# Slack webhook for error alerts (optional)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Email configuration (for sending completed sheets to print team)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# ===========================================
# Configuration: Sheet Settings
# ===========================================
# Sheet size: a3, 12x18, or 17x22
DTF_SHEET_SIZE=12x18

# Max designs per sheet (typically 4 for optimal nesting)
MAX_DESIGNS_PER_SHEET=4

# Bleed margin in mm
BLEED_MM=10

# Edge margin in mm
EDGE_MARGIN_MM=15